COMPOSE_PROJECT_NAME=mag7-supply-chain-dev

NEO4J_USER=neo4j
NEO4J_PASSWORD=mag7-dev-password
NEO4J_DB=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://127.0.0.1:7687

REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_RAW=mag7-raw
MINIO_BUCKET_CURATED=mag7-curated
MINIO_BUCKET_EXPORTS=mag7-exports
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true

API_PORT=3001
API_BASE_URL=http://127.0.0.1:3001/api/v1
GRAPH_SNAPSHOT_VERSION=local-dev
