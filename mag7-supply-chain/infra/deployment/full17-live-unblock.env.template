# Mag7 full.17 external live validation template
# Copy this file to a private local path, fill the placeholders, then:
#   set -a
#   source /path/to/your.env
#   set +a

REPO_ROOT=/workspace/project/mag7-supply-chain
BACKEND_DIR=/workspace/project/mag7-supply-chain/backend
PACKAGE_DIR=/workspace/agents/evidence-collector/output/mag7-full-package
EXPECTED_PACKAGE_SNAPSHOT=snapshot:2026-06-15.full.17
VALIDATION_OUTPUT_DIR=/tmp/mag7-live-acceptance-full17
API_BASE=http://127.0.0.1:4000

# Must stay live. Prototype/mock is never acceptable for this checklist.
GRAPH_RUNTIME_MODE=live

# Provider-neutral Neo4j binding.
# Examples:
#   bolt://neo4j-host:7687
#   neo4j://neo4j-host:7687
#   neo4j+s://neo4j-host:7687
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Prefer an isolated validation database if your provider supports it.
# If not, provision an isolated instance instead of sharing production data.
NEO4J_DATABASE=

# Provider-neutral Redis binding.
# Examples:
#   redis://redis-host:6379/0
#   rediss://redis-host:6380/0
REDIS_URL=

# Local backend bind for smoke tests.
HOST=127.0.0.1
PORT=4000

# Optional if cross-origin browser smoke is needed later.
CORS_ORIGIN=
