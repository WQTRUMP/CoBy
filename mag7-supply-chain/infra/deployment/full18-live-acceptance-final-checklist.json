        "dependencies.redis.status = up",
        "所有带 source 的业务响应都等于 neo4j"
      ]
    }
  ],
  "rollback_policy": {
    "allowed_only_on_isolated_resources": true,
    "required": [
      "保留完整输出目录作为证据",
      "停止临时 backend 进程",
      "销毁或清理隔离 Neo4j 验收库",
      "清理隔离 Redis 实例或独立 DB index",
      "若已创建 Cloudflare 预备记录，仅在未切正式流量前回滚"
    ],
    "forbidden": [
      "切回 prototype",
      "切回 mock",
      "把 degraded 或 503 当成通过",
      "在共享生产图数据库上做首次验收"
    ]
  },
  "post_approval_24h_plan": [
    "0-2 小时：确认 Cloudflare zone、域名策略、托管 Neo4j/Redis/backend 运行器已就绪，但不切正式流量",
    "2-6 小时：填充 env，执行 live-acceptance-commands.sh，收集 result/import/http 证据",
    "6-12 小时：仅在 result.json.passed=true 后接入 Cloudflare DNS、证书、/api 代理或 api 子域，并在最终路由重跑 smoke",
    "12-24 小时：复查 /api/v1/health、detail、search、path、evidence 样本；若 products.json 仍未正式接入，则继续维持 unknown:no_product_inventory"
