  "cloudflare_domain_sequence": [
    {
      "order": 1,
      "step": "仅批准 Cloudflare 连接与域名规划，不做正式流量切换",
      "gate": "prototype 可候选部署；real_data_launch 仍 blocked"
    },
    {
      "order": 2,
      "step": "先准备隔离的托管 Neo4j/Redis 与 backend 运行器，完成 provider-neutral live 验收",
      "gate": "result.json.passed 必须为 true"
    },
    {
      "order": 3,
      "step": "验收通过后再接入 Cloudflare DNS、证书、同源 /api 代理或 api 子域",
      "gate": "不得先接正式域名再补写库验收"
    },
    {
      "order": 4,
      "step": "若采用分域，前端补齐 VITE_GRAPH_API_BASE_URL，后端补齐 CORS_ORIGIN",
      "gate": "HTTP smoke 需在最终域名或最终代理路径上复跑"
    }
  ],
  "execution": [
    {
      "id": "preflight",
      "command": "bash infra/deployment/live-acceptance-commands.sh --mode external --output-dir ${VALIDATION_OUTPUT_DIR:-/tmp/mag7-live-acceptance-full18}",
