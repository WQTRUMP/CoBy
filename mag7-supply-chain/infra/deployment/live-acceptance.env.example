REPO_ROOT=/workspace/project/mag7-supply-chain
BACKEND_DIR=/workspace/project/mag7-supply-chain/backend
PACKAGE_DIR=/workspace/agents/evidence-collector/output/mag7-full-package
EXPECTED_PACKAGE_SNAPSHOT=snapshot:2026-06-15.full.16
API_BASE=http://127.0.0.1:4000

# 默认必须保持 live；只有显式 prototype 才允许 mock。
GRAPH_RUNTIME_MODE=live

# 以下 5 项是 external Neo4j/Redis live 验收的最小必填输入。
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mag7-dev-password
NEO4J_DATABASE=neo4j
REDIS_URL=redis://127.0.0.1:6379

# 以下变量仅用于本地 backend 监听、preview 基线或 docker 端口覆盖。
PORT=4000
HOST=127.0.0.1
CORS_ORIGIN=http://127.0.0.1:5174

COMPOSE_PROJECT_NAME=mag7-supply-chain-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
REDIS_PORT=6379

# docker 模式下可用；external 模式通常不需要改动。
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
