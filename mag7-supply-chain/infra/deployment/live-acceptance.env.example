REPO_ROOT=/workspace/project/mag7-supply-chain
BACKEND_DIR=/workspace/project/mag7-supply-chain/backend
PACKAGE_DIR=/workspace/agents/evidence-collector/output/mag7-full-package
EXPECTED_PACKAGE_SNAPSHOT=snapshot:2026-06-15.full.18
EXPECTED_RELATION_COUNT=312
EXPECTED_EVIDENCE_COUNT=410
API_BASE=http://127.0.0.1:4000

# 默认必须保持 live；任何未满足依赖的情况都必须显式失败，不能回退 mock。
GRAPH_RUNTIME_MODE=live

# external 模式最小必填输入。auto 模式下若这 5 项都存在，脚本会优先使用 external。
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
REDIS_URL=

# backend 本地监听地址；若不改端口，通常无需修改。
PORT=4000
HOST=127.0.0.1

# 分域部署时建议同步填写这两个变量；若通过同源 /api 代理接入，可保持为空。
VITE_GRAPH_API_BASE_URL=
CORS_ORIGIN=

# docker 模式默认端口。只有当 auto 退回 docker，或显式 --mode docker 时才会使用。
COMPOSE_PROJECT_NAME=mag7-supply-chain-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
