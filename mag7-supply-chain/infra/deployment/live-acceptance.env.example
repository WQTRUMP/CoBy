# superseded: 本模板仅保留 full.18 live 验收审计用途。
# 当前 authoritative 发布边界已统一为 snapshot:2026-06-15.full.18 / published=332/444 / all-candidates=341/459 / candidate-only=9/15。
# 正式 post-audit 入口已切换为 v3；旧的 312/410、327/435、350/476 与 post-audit-v2 只保留 historical/audit-only 语义。
# 当前正式入口与发布边界请改用：
# - infra/deployment/deployment-manifest.json
# - infra/deployment/products-candidate.json
# - /workspace/agents/devops/output/final-release-index-post-audit-v3/final-release-index-post-audit-v3-report.md
REPO_ROOT=/workspace/project/mag7-supply-chain
BACKEND_DIR=/workspace/project/mag7-supply-chain/backend
PACKAGE_DIR=/workspace/agents/evidence-collector/output/mag7-full-package
EXPECTED_PACKAGE_SNAPSHOT=snapshot:2026-06-15.full.18
EXPECTED_RELATION_COUNT=332
EXPECTED_EVIDENCE_COUNT=444
API_BASE=http://127.0.0.1:4000

# historical_audit_only: 以下旧计数只对应 superseded full.18 辅助链，不得再被脚本或人工读取为当前 authoritative 口径。
HISTORICAL_FULL18_PUBLISHED_RELATION_COUNT=312
HISTORICAL_FULL18_PUBLISHED_EVIDENCE_COUNT=410
HISTORICAL_POST_AUDIT_V3_PREDECESSOR_PUBLISHED_RELATION_COUNT=327
HISTORICAL_POST_AUDIT_V3_PREDECESSOR_PUBLISHED_EVIDENCE_COUNT=435
HISTORICAL_POST_AUDIT_V3_PREDECESSOR_ALL_CANDIDATES_RELATION_COUNT=350
HISTORICAL_POST_AUDIT_V3_PREDECESSOR_ALL_CANDIDATES_EVIDENCE_COUNT=476

# 默认必须保持 live；任何未满足依赖的情况都必须显式失败，不能回退 mock。
GRAPH_RUNTIME_MODE=live

# external 模式最小必填输入。auto 模式下若这 5 项都存在，脚本会优先使用 external。
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
REDIS_URL=

# backend 本地监听地址；若不改端口，通常无需修改。
PORT=4000
HOST=127.0.0.1

# 分域部署时建议同步填写这两个变量；若通过同源 /api 代理接入，可保持为空。
VITE_GRAPH_API_BASE_URL=
CORS_ORIGIN=

# docker 模式默认端口。只有当 auto 退回 docker，或显式 --mode docker 时才会使用。
COMPOSE_PROJECT_NAME=mag7-supply-chain-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
