{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": ".tmp-contract-tests",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/adapters/**/*.ts",
    "src/mocks/**/*.ts",
    "src/services/**/*.ts",
    "src/types/**/*.ts",
    "packages/contracts/src/**/*.ts"
  ]
}
